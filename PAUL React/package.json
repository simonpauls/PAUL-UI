{
  "name": "@paul/react",
  "version": "0.1.0",
  "type": "module",
  "license": "GPL-3.0",
  "author": "PAUL Team",
  "description": "The official React component library for the PAUL Design System",
  "keywords": [
    "react",
    "component-library",
    "design-system",
    "paul",
    "accessible",
    "ui"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/simonpauls/PAUL-UI.git",
    "directory": "PAUL React"
  },
  "bugs": {
    "url": "https://github.com/simonpauls/PAUL-UI/issues"
  },
  "homepage": "https://github.com/simonpauls/PAUL-UI/tree/main/PAUL%20React#readme",
  "main": "./dist/paul-react.umd.js",
  "module": "./dist/paul-react.es.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/paul-react.es.js",
      "require": "./dist/paul-react.umd.js"
    },
    "./style.css": "./dist/react.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "preview": "vite preview",
    "demo:build": "esbuild demo/demo.tsx --bundle --outfile=demo/demo.js --jsx=automatic",
    "demo": "pnpm demo:build && esbuild --servedir=demo",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "esbuild": "^0.27.4",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "identity-obj-proxy": "^3.0.0",
    "jsdom": "^29.0.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1",
    "vite-plugin-css-injected-by-js": "^4.0.1",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.1.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@paul/ui": "workspace:*",
    "clsx": "^2.1.1",
    "react-aria-components": "^1.16.0",
    "react-router-dom": "^7.13.1"
  }
}
